---
import "@/styles/global.css";
import "@fontsource-variable/inter";
import "@fontsource-variable/noto-sans-jp";
import "@fontsource-variable/geist-mono";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { siteConfig } from "@/site.config";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    articleDate?: Date;
}

const { title, description, image, articleDate } = Astro.props;
const { siteName, siteDescription, social } = siteConfig;

const pageTitle = title ? `${title} | ${siteName}` : siteName;
const pageDescription = description || siteDescription;

// Use Astro.site defined in astro.config.mjs
const siteUrl = Astro.site;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

// Determine OG image URL
const ogImageURL = image 
    ? new URL(image, siteUrl) 
    : title 
        ? new URL(`/og/${Astro.params.id}.png`, siteUrl)
        : new URL("/og/default.png", siteUrl); // Default image
---

<!doctype html>
<html lang="ja">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />

        <!-- SEO -->
        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph -->
        <meta property="og:type" content={articleDate ? "article" : "website"} />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:site_name" content={siteName} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={Astro.url} />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        <meta name="twitter:image" content={ogImageURL} />
        {social.twitter && <meta name="twitter:site" content={`@${social.twitter}`} />}

        {articleDate && (
            <meta property="article:published_time" content={articleDate.toISOString()} />
        )}
    </head>
    <body class="flex min-h-screen flex-col">
        <Header />
        <main class="container mx-auto w-full max-w-7xl grow px-6 pt-16">
            <slot />
        </main>
        <Footer />
    </body>
</html>
