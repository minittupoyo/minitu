---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection, render } from "astro:content";
import PostNavigation from "@/components/PostNavigation.astro";
import TableOfContents from "@/components/TableOfContents.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog", ({ data }) => {
        return import.meta.env.PROD ? data.draft !== true : true;
    });

    // 日付順（降順：新しい順）にソート
    const sortedPosts = posts.sort(
        (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
    );

    return sortedPosts.map((post, index) => {
        const nextPost = index > 0 ? sortedPosts[index - 1] : null; // より新しい記事
        const prevPost =
            index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null; // より古い記事

        return {
            params: { id: post.id },
            props: { post, prevPost, nextPost },
        };
    });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
---

<Layout
    title={post.data.title}
    description={post.data.description}
    articleDate={post.data.date}
>
    <section class="flex flex-col py-16">
        <div class="flex flex-col items-center space-y-4 text-center">
            <p class="text-7xl">{post.data.emoji}</p>
            <div class="flex flex-col items-center space-y-2">
                <h1 class="text-3xl font-bold md:text-4xl">
                    {post.data.title}
                </h1>
                <p class="max-w-2xl text-lg font-medium text-slate-700">
                    {post.data.description}
                </p>
            </div>
            <p class="flex flex-row items-center gap-2 text-slate-500">
                <Icon name="tabler:calendar-week" />
                <span
                    >{
                        post.data.date.toLocaleDateString("ja-JP", {
                            year: "numeric",
                            month: "2-digit",
                            day: "2-digit",
                        })
                    }</span
                >
            </p>
        </div>
    </section>
    <section class="flex flex-col border-t border-slate-100 py-12">
        <div class="grid w-full grid-cols-1 gap-12 md:grid-cols-12">
            <div class="prose prose-slate w-full min-w-full md:col-span-8">
                <Content />
            </div>
            <aside class="hidden md:col-span-4 md:block">
                <div class="sticky top-24">
                    <TableOfContents headings={headings} />
                </div>
            </aside>
        </div>
        <PostNavigation prevPost={prevPost} nextPost={nextPost} />
    </section>
</Layout>
