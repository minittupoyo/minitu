---
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/site.config";

const { siteName, navLinks, social } = siteConfig;
---

<header
    class="fixed top-0 left-0 z-50 h-16 w-full border-b border-slate-200 bg-white/70 backdrop-blur-sm"
>
    <div
        class="container relative mx-auto flex h-full w-full max-w-7xl flex-row items-center justify-between px-6"
    >
        <a href="/" class="text-xl font-bold transition-colors hover:text-slate-700">{siteName}</a>
        
        {/* Desktop Navigation */}
        <nav class="hidden md:flex flex-row items-center gap-6">
            {navLinks.map((link) => (
                <a
                    href={link.href}
                    class="text-sm font-medium text-slate-500 transition-all duration-150 hover:text-slate-900"
                >
                    {link.label}
                </a>
            ))}
            <a
                href={social.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 transition-all duration-150 hover:text-slate-900"
                aria-label="GitHub"
            >
                <Icon name="tabler:brand-github" class="text-xl" />
            </a>
        </nav>

        {/* Mobile Menu Toggle */}
        <button
            id="mobile-menu-toggle"
            class="group flex items-center justify-center rounded-lg p-2 text-slate-500 transition-colors hover:bg-slate-100 hover:text-slate-900 md:hidden"
            aria-label="Toggle Menu"
        >
            <Icon name="tabler:menu-2" class="text-2xl transition-transform duration-300 group-[.is-active]:rotate-90" />
        </button>

        {/* Mobile Dropdown Menu (Compact) */}
        <div
            id="mobile-dropdown"
            class="absolute top-16 right-6 w-48 scale-95 opacity-0 pointer-events-none rounded-2xl border border-slate-200 bg-white/95 p-2 shadow-xl backdrop-blur-xl transition-all duration-300 md:hidden"
        >
            <nav class="flex flex-col gap-1">
                <a href="/" class="flex w-full items-center rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 hover:text-slate-900 active:bg-slate-100">Home</a>
                {navLinks.map((link) => (
                    <a href={link.href} class="flex w-full items-center rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 hover:text-slate-900 active:bg-slate-100">
                        {link.label}
                    </a>
                ))}
                <div class="my-1 border-t border-slate-100"></div>
                <a
                    href={social.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex w-full items-center rounded-xl px-4 py-3 text-sm font-medium text-slate-500 transition-colors hover:bg-slate-50 hover:text-slate-900 active:bg-slate-100 gap-2"
                >
                    <Icon name="tabler:brand-github" class="text-lg" />
                    <span>GitHub</span>
                </a>
            </nav>
        </div>
    </div>
</header>

<script>
    function setupMobileMenu() {
        const toggleBtn = document.getElementById('mobile-menu-toggle');
        const dropdown = document.getElementById('mobile-dropdown');
        const links = dropdown?.querySelectorAll('a');

        const toggleMenu = () => {
            const isOpen = dropdown?.classList.contains('opacity-100');
            if (isOpen) {
                closeMenu();
            } else {
                openMenu();
            }
        };

        const openMenu = () => {
            dropdown?.classList.remove('opacity-0', 'pointer-events-none', 'scale-95');
            dropdown?.classList.add('opacity-100', 'scale-100');
            toggleBtn?.classList.add('is-active');
            
            // Close when clicking outside
            document.addEventListener('click', closeOnClickOutside);
        };

        const closeMenu = () => {
            dropdown?.classList.remove('opacity-100', 'scale-100');
            dropdown?.classList.add('opacity-0', 'scale-95');
            toggleBtn?.classList.remove('is-active');
            
            setTimeout(() => {
                dropdown?.classList.add('pointer-events-none');
            }, 200);

            document.removeEventListener('click', closeOnClickOutside);
        };

        const closeOnClickOutside = (e: MouseEvent) => {
            if (!toggleBtn?.contains(e.target as Node) && !dropdown?.contains(e.target as Node)) {
                closeMenu();
            }
        };

        toggleBtn?.addEventListener('click', toggleMenu);
        
        links?.forEach(link => {
            link.addEventListener('click', closeMenu);
        });

        // ESC key to close
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeMenu();
        });
    }

    // Initialize on page load
    setupMobileMenu();

    // Re-initialize after view transitions
    document.addEventListener('astro:after-swap', setupMobileMenu);
</script>

<style>
    /* Dropdown transition effect */
    #mobile-dropdown {
        transform-origin: top right;
    }
</style>
