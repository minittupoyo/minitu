---
import { Icon } from "astro-icon/components";
---

<header
    class="fixed top-0 left-0 z-50 h-16 w-full border-b border-slate-200 bg-white/70 backdrop-blur-sm"
>
    <div
        class="container mx-auto flex h-full w-full max-w-7xl flex-row items-center justify-between px-6"
    >
        <a href="/" class="text-xl font-bold">みにっつ</a>
        <nav class="flex flex-row items-center gap-4">
            <a
                href="/blog"
                class="text-slate-500 transition-all duration-150 hover:text-slate-700"
                >Blog</a
            >
            <a
                href="/about"
                class="text-slate-500 transition-all duration-150 hover:text-slate-700"
                >About</a
            >
            <a
                href="/tags"
                class="text-slate-500 transition-all duration-150 hover:text-slate-700"
                >Tags</a
            >
            <a
                href="/tags"
                class="text-slate-500 transition-all duration-150 hover:text-slate-700"
                ><Icon name="tabler:brand-github" /></a
            >
        </nav>
    </div>
</header>
