---
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/site.config";

const { siteName, siteDescription, navLinks, social } = siteConfig;
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto border-t border-slate-100 bg-white py-12">
    <div class="container mx-auto max-w-7xl px-6">
        <div class="flex flex-col items-center justify-between gap-8 md:flex-row md:gap-0">
            <div class="flex flex-col items-center gap-4 md:items-start">
                <a href="/" class="text-xl font-bold text-slate-900">{siteName}</a>
                <p class="text-sm text-slate-500">
                    {siteDescription}
                </p>
            </div>

            <nav class="flex flex-wrap justify-center gap-x-8 gap-y-4">
                <a href="/" class="text-sm font-medium text-slate-600 transition-colors hover:text-slate-900">Home</a>
                {navLinks.map((link) => (
                    <a href={link.href} class="text-sm font-medium text-slate-600 transition-colors hover:text-slate-900">
                        {link.label}
                    </a>
                ))}
            </nav>

            <div class="flex flex-col items-center gap-4 md:items-end">
                <div class="flex items-center gap-4">
                    <a
                        href={social.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-slate-400 transition-colors hover:text-slate-900"
                        aria-label="GitHub"
                    >
                        <Icon name="tabler:brand-github" class="text-xl" />
                    </a>
                </div>
                <p class="text-xs text-slate-400">
                    &copy; {currentYear} {siteName}. Built with Astro & Bun.
                </p>
            </div>
        </div>
    </div>
</footer>
